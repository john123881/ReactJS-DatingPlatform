# =========================================================================
# Taipei Date - 前端環境變數範本 (.env.example)
# =========================================================================
# 使用方法：
# 1. 複製此文件並更名為 .env 或 .env.local
# 2. 填入對應的 API Key 與 設定值
# =========================================================================

# --- API 伺服器配置 ---
# 後端 API 的基礎路徑 (例如: https://your-api.com)
NEXT_PUBLIC_API_URL=https://taipei-date-node.onrender.com
# Socket.io 伺服器路徑
NEXT_PUBLIC_SOCKET_URL=https://taipei-date-node.onrender.com

# --- Firebase 配置 (主要用於 Google Auth 登入功能) ---
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# --- Google Maps 配置 (用於酒吧地圖功能) ---
# 需在 Google Cloud Console 開啟 Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
